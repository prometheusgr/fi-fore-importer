{
  "name": "@fi-fore/importer",
  "version": "0.1.1",
  "description": "Standalone importer package seed for fi-fore",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "SECURITY.md",
    "PRIVACY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "npm run start:standalone",
    "start:standalone": "npm run build && node dist/standalone/start.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run test:typecheck",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "finance",
    "import",
    "csv",
    "transactions",
    "bank-import"
  ],
  "author": "fi-fore Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
